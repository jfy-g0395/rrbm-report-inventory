Hibernate: 
    SELECT
        source,
        COUNT(*) as order_count,
        COALESCE(SUM(total), 0) as revenue 
    FROM
        orders 
    WHERE
        status != 'CANCELLED'   
        AND created_at::date >= ?   
        AND created_at::date <= ? 
    GROUP BY
        source 
    ORDER BY
        revenue DESC
Hibernate: 
    SELECT
        agent_name,
        source,
        COUNT(*) as order_count,
        COALESCE(SUM(total), 0) as revenue 
    FROM
        orders 
    WHERE
        status != 'CANCELLED'   
        AND source IN ('AGENT', 'RESELLER', 'DISTRIBUTOR')   
        AND agent_name IS NOT NULL 
        AND agent_name != ''   
        AND created_at::date >= ?   
        AND created_at::date <= ? 
    GROUP BY
        agent_name,
        source 
    ORDER BY
        revenue DESC 
    LIMIT
        10
Hibernate: 
    SELECT
        created_at::date as sale_date,
        COUNT(*) as order_count,
        COALESCE(SUM(total), 0) as revenue 
    FROM
        orders 
    WHERE
        status != 'CANCELLED'   
        AND created_at::date >= ?   
        AND created_at::date <= ? 
    GROUP BY
        created_at::date 
    ORDER BY
        revenue DESC 
    LIMIT
        3
Hibernate: 
    SELECT
        COUNT(*),
        COALESCE(SUM(o.total), 0),
        COALESCE(SUM(oi_sum.qty), 0) 
    FROM
        orders o 
    LEFT JOIN
        (  SELECT
            order_id, SUM(quantity) as qty 
        FROM
            order_items 
        GROUP BY
            order_id) oi_sum 
            ON oi_sum.order_id = o.id 
    WHERE
        DATE(o.created_at) BETWEEN ? AND ?   
        AND o.status != 'CANCELLED'   
        AND o.source = 'ECOMMERCE'
Hibernate: 
    SELECT
        oi.product_name,
        SUM(oi.quantity) as qty,
        COALESCE(SUM(oi.subtotal), 0) as revenue 
    FROM
        order_items oi 
    JOIN
        orders o 
            ON oi.order_id = o.id 
    WHERE
        o.status != 'CANCELLED'   
        AND o.created_at::date >= ?   
        AND o.created_at::date <= ?   
        AND oi.product_name ILIKE '%Pizza Box%' 
    GROUP BY
        oi.product_name 
    ORDER BY
        qty DESC
Hibernate: 
    SELECT
