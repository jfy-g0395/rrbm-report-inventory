    SELECT
        o.created_at::date as sale_date,
        COUNT(CASE 
            WHEN o.source != 'ECOMMERCE' 
                THEN 1 
        END) as direct_orders,
        COUNT(CASE 
            WHEN o.source  = 'ECOMMERCE' 
                THEN 1 
        END) as ecom_orders,
        COUNT(*) as total_orders,
        COALESCE(SUM(pizza.pizza_qty), 0) as pizza_qty,
        COALESCE(SUM(o.total), 0) as revenue 
    FROM
        orders o 
    LEFT JOIN
        (   SELECT
            order_id, SUM(quantity) as pizza_qty   
        FROM
            order_items   
        WHERE
            product_name ILIKE '%Pizza Box%'   
        GROUP BY
            order_id ) pizza 
            ON pizza.order_id = o.id 
    WHERE
        o.status != 'CANCELLED'   
        AND o.created_at::date >= ?   
        AND o.created_at::date <= ? 
    GROUP BY
        o.created_at::date 
    ORDER BY
        o.created_at::date ASC
