# Copy this file to .env and fill in real values before running docker-compose
# NEVER commit .env to Git

# PostgreSQL password
DB_PASSWORD=change_me_strong_password

# JWT signing secret — must be at least 32 characters
# Generate a strong one with: openssl rand -hex 32
RRBM_JWT_SECRET=change_me_minimum_256_bit_secret_key_here

# Initial master key — seeded on first boot only (when DB has no master keys)
# Change immediately after first login via Settings UI
RRBM_INITIAL_MASTER_KEY=change_me_strong_key_min_8_chars

# Allowed browser origins for CORS (comma-separated, NO wildcard in production).
# Set to your exact frontend domain(s), e.g. https://app.example.com,https://example.com
RRBM_CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:80

# Production hardening: refuse to boot if RRBM_JWT_SECRET is unset (uses dev fallback).
# Leave false for local dev; set true in production.
RRBM_FAIL_ON_DEFAULT_JWT_SECRET=false
